#!/usr/bin/env bash

IFS=$'\n'
set -f
export LC_NUMERIC=C

colors=$(gdbus call --session --dest org.gnome.Shell.Screenshot --object-path /org/gnome/Shell/Screenshot --method org.gnome.Shell.Screenshot.PickColor)
colors=($(echo "$colors" | command grep -o "[0-9\.]*"))

for ((i = 0; i < ${#colors[@]}; i++)); do
    colors[i]=$(printf '%.0f' "$(echo "${colors[$i]} * 255" | bc)")
done

hex=$(printf "#%02x%02x%02x\n" "${colors[0]}" "${colors[1]}" "${colors[2]}")
echo "$hex"

if [ -n "$WAYLAND_DISPLAY" ]; then
    wl-copy "$hex"
elif [ -n "$DISPLAY" ]; then
    echo "$hex" | xclip -sel c -i
fi
