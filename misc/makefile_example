.POSIX:
.SILENT:
.SUFFIXES:
.SUFFIXES: .c .o
.PHONY: all options clean

RAYLIB_INC = ./raylib
RAYLIB_LIB = ./raylib

CC = cc
RM ?= rm -f
CFLAGS = -std=c99 -Wall -Wextra -Wpedantic -g -Og -I $(RAYLIB_INC)
LDFLAGS = -L $(RAYLIB_LIB) -l:libraylib.a -lGL -lm -lpthread -ldl -lrt -lX11

prog = game
objs = $(prog).o util.o

all: $(prog)
options:
	@echo "$(prog) build options:"
	@echo "CFLAGS  = $(CFLAGS)"
	@echo "LDFLAGS = $(LDFLAGS)"
	@echo "CC      = $(CC)"
clean:
	$(RM) *.o $(prog)

$(prog): $(objs)
	@echo "  LD      $@"
	$(CC) -o $@ $(objs) $(CFLAGS) $(LDFLAGS)
$(prog).o: $(prog).c $(prog).h util.h
util.o: util.c util.h

.c.o:
	@echo "  CC      $@"
	$(CC) -c $< -o $@ $(CFLAGS)

