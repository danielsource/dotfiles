[user]
    email = 79308609+danielsource@users.noreply.github.com
    name = daniel.source
[init]
    defaultBranch = main
[credential "https://github.com"]
    helper = !gh auth git-credential
[color "diff"]
    meta = blue
[include]
    path = ~/.gitinfo
[alias]
    adog = log --all --decorate --oneline --graph
