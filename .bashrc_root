case $- in *i*) ;; *) return ;; esac

stty -ixon
shopt -s checkwinsize
shopt -s histappend
HISTCONTROL=ignoreboth
HISTSIZE=1000
HISTFILESIZE=10000

case "$TERM" in
xterm-color|*-256color)
	PS1='\[\033[01;30m\]$?\[\033[00m\] \[\033[01;31m\]\w\[\033[00m\] \[\033[01;37m\]\$\[\033[00m\] '
	;;
*)
	PS1='$? \u@\h:\w \$ '
	;;
esac

case "$TERM" in
xterm*|rxvt*|tmux-256color|st-256color)
	PS1="\[\e]0;\u@\h: \w\a\]$PS1"
	;;
*)
	;;
esac

alias ls='LC_COLLATE=C ls --color=auto --group-directories-first'
alias l='ls -lahG'
